<% /* Site footer with icon links. Pass { links: { discord, github } }; the Info button is always the internal /about.html page. Rendered by the base layout on every page. */ -%>
<footer class="site-foot">
  <nav class="foot-links" aria-label="Links">
    <% if (it.links && it.links.discord) { -%>
    <a class="foot-btn" href="<%= it.links.discord %>" title="Discord" aria-label="Discord" target="_blank" rel="noopener"><svg class="foot-brand" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.32 4.37A19.79 19.79 0 0 0 15.45 3a13.8 13.8 0 0 0-.62 1.27 18.27 18.27 0 0 0-5.66 0A12.6 12.6 0 0 0 8.55 3a19.74 19.74 0 0 0-4.87 1.37C.6 8.97-.24 13.46.18 17.88a19.9 19.9 0 0 0 6.06 3.06c.49-.67.92-1.38 1.3-2.12a12.9 12.9 0 0 1-2.05-.99c.17-.13.34-.26.5-.39a14.21 14.21 0 0 0 12.04 0c.16.14.33.27.5.4-.65.39-1.34.72-2.05.98.37.74.81 1.45 1.3 2.12a19.84 19.84 0 0 0 6.06-3.06c.5-5.18-.84-9.63-3.52-13.51ZM8.02 15.16c-1.18 0-2.15-1.09-2.15-2.43 0-1.34.95-2.43 2.15-2.43 1.2 0 2.17 1.1 2.15 2.43 0 1.34-.95 2.43-2.15 2.43Zm7.96 0c-1.18 0-2.15-1.09-2.15-2.43 0-1.34.95-2.43 2.15-2.43 1.2 0 2.17 1.1 2.15 2.43 0 1.34-.94 2.43-2.15 2.43Z"/></svg></a>
    <% } -%>
    <a class="foot-btn" href="/about.html" title="About" aria-label="About"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><path d="M12 8h.01"/></svg></a>
    <% if (it.links && it.links.github) { -%>
    <a class="foot-btn" href="<%= it.links.github %>" title="GitHub" aria-label="GitHub" target="_blank" rel="noopener"><svg class="foot-brand" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg></a>
    <% } -%>
  </nav>
</footer>
